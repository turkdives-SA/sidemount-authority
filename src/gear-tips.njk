---
layout: base.njk
title: Gear Tips
description: Honest sidemount scuba gear reviews and technique tips from a working RAID Tech Trimix Sidemount Instructor. Real-world testing, no sponsored fluff.
permalink: /gear-tips/
---

<section class="page-hero">
  <p class="page-label">Field-tested insight</p>
  <h1>Gear Tips</h1>
  <p class="page-intro">Real-world reviews and technical insights from thousands of hours in sidemount configuration. No sponsored fluff — just what works at depth.</p>
</section>

<section class="posts-grid">
  {% set gearposts = collections.posts | reverse %}
  {% set filtered = [] %}
  {% for post in gearposts %}
    {% if post.data.category == "gear" or not post.data.category %}
      {% set filtered = (filtered.push(post), filtered) %}
    {% endif %}
  {% endfor %}

  <p class="posts-count">{{ filtered | length }} posts</p>

  {% for post in filtered %}
  <article class="post-card">
    {% if post.data.hero_image %}
    <a href="{{ post.url }}">
      <img src="{{ post.data.hero_image }}" alt="{{ post.data.hero_image_alt }}" loading="lazy">
    </a>
    {% endif %}
    <div class="post-card__body">
      <div class="post-card__meta">
        <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
        {% if post.data.readTime %}<span>{{ post.data.readTime }} min read</span>{% endif %}
      </div>
      <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      <p>{{ post.data.description }}</p>
      <a href="{{ post.url }}" class="read-more">Read More →</a>
    </div>
  </article>
  {% endfor %}
</section>
