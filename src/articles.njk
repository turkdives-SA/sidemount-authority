---
layout: base.njk
title: Articles
description: Field notes, industry opinion, safety standards, and training insights from a RAID Tech Trimix Sidemount Instructor.
permalink: /articles/
---

<section class="page-hero">
  <p class="page-label">From the field</p>
  <h1>Articles</h1>
  <p class="page-intro">Gear. Safety. Standards. Training. No filler — just what matters underwater and in the industry.</p>
</section>

<section class="posts-grid">
  <p class="posts-count">{{ collections.posts | length }} articles</p>

  {% for post in collections.posts | reverse %}
  <article class="post-card">
    {% if post.data.hero_image %}
    <a href="{{ post.url }}">
      <img src="{{ post.data.hero_image }}" alt="{{ post.data.hero_image_alt }}" loading="lazy">
    </a>
    {% endif %}
    <div class="post-card__body">
      <div class="post-card__meta">
        <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
        {% if post.data.readTime %}<span>{{ post.data.readTime }} min read</span>{% endif %}
        {% if post.data.category %}<span class="post-tag">{{ post.data.category }}</span>{% endif %}
      </div>
      <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      <p>{{ post.data.description }}</p>
      <a href="{{ post.url }}" class="read-more">Read More →</a>
    </div>
  </article>
  {% endfor %}
</section>
