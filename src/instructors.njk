---
layout: base.njk
title: Recommended Instructors
description: Sidemount instructors around the world that I recommend for quality training.
permalink: /instructors/
---

<div class="instructors-page">

  <!-- Page Hero -->
  <header class="page-hero">
    <div class="container">
      <span class="eyebrow">Worldwide network</span>
      <h1>Recommended Instructors</h1>
      <p>These are sidemount instructors around the world that I personally recommend. Each one meets the standards I consider non-negotiable for quality sidemount instruction.</p>
    </div>
  </header>

  <!-- Instructors Table -->
  <section class="instructors-section" aria-labelledby="instructors-heading">
    <div class="container">
      <div class="sr-only" id="instructors-heading">Recommended instructor directory</div>

      {% if instructors.length %}
      <div class="instructors-table-wrap">
        <table class="instructors-table">
          <thead>
            <tr>
              <th scope="col">Name</th>
              <th scope="col">Location</th>
              <th scope="col">Agency</th>
              <th scope="col">Contact</th>
              <th scope="col">Notes</th>
            </tr>
          </thead>
          <tbody>
            {% for instructor in instructors %}
            <tr>
              <td>{{ instructor.name }}</td>
              <td>{{ instructor.location }}</td>
              <td><span class="mono">{{ instructor.agency }}</span></td>
              <td>
                {% if instructor.email %}
                <a href="mailto:{{ instructor.email }}">{{ instructor.email }}</a>
                {% else %}
                <span class="text-faint mono">—</span>
                {% endif %}
              </td>
              <td class="text-dim" style="font-size:0.875rem;">{{ instructor.notes or "—" }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% else %}
      <div class="no-posts">
        <p class="eyebrow">Coming Soon</p>
        <p>Instructor listings will be published shortly.</p>
      </div>
      {% endif %}

    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band" aria-labelledby="instructor-cta-heading">
    <div class="container">
      <h2 id="instructor-cta-heading">Are you a sidemount instructor?</h2>
      <p>If you believe you meet the standards for inclusion on this list, get in touch and let's talk.</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn btn-signal">Get in Touch</a>
      </div>
    </div>
  </section>

</div>
