---
layout: base.njk
title: Articles
description: Field notes, industry opinion, safety standards, and training insights from a RAID Tech Trimix Sidemount Instructor.
permalink: /articles/
---
<section class="page-hero">
  <p class="page-label">From the field</p>
  <h1>Articles</h1>
  <p class="page-intro">Gear. Safety. Standards. Training. No filler — just what matters underwater and in the industry.</p>
</section>

<section class="articles-filters" aria-label="Filter articles by category">
  <button class="filter-btn active" data-filter="all">All</button>
  <button class="filter-btn" data-filter="gear">Gear</button>
  <button class="filter-btn" data-filter="safety">Safety & Standards</button>
  <button class="filter-btn" data-filter="industry">Industry</button>
  <button class="filter-btn" data-filter="training">Training</button>
</section>

<section class="posts-section">
  <div class="container">
  <p class="posts-count"><span id="visible-count">{{ collections.posts | length }}</span> articles</p>
  <p class="no-articles-msg" id="no-articles" style="display:none; text-align:center; color:var(--sa-chrome-dim); padding:3rem 1rem; font-family:var(--font-mono); font-size:0.85rem;">No articles in this category yet. Check back soon.</p>
  {% for post in collections.posts | reverse %}
  <article class="post-card" data-category="{{ post.data.category or 'gear' }}">
    {% if post.data.hero_image %}
    <a href="{{ post.url }}" class="post-card-image">
      <img src="{{ post.data.hero_image }}" alt="{{ post.data.hero_image_alt }}" loading="lazy">
    </a>
    {% else %}
    <a href="{{ post.url }}" class="post-card-image post-card-image--placeholder"></a>
    {% endif %}
    <div class="post-card-body">
      <div class="post-card-meta">
        <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
        {% if post.data.readTime %}<span>{{ post.data.readTime }} min read</span>{% endif %}
        {% if post.data.category %}<span class="post-tag post-tag--{{ post.data.category }}">{{ post.data.category }}</span>{% endif %}
      </div>
      <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
      <p>{{ post.data.description }}</p>
      <a href="{{ post.url }}" class="read-more">Read More →</a>
    </div>
  </article>
 {% endfor %}
  </div>
</section>

{% raw %}
<script>
(function() {
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.post-card[data-category]');
  const countEl = document.getElementById('visible-count');
  const msgEl = document.getElementById('no-articles');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      let visible = 0;
      cards.forEach(card => {
        const cat = card.dataset.category;
        if (filter === 'all' || cat === filter) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });
      if (countEl) countEl.textContent = visible;
      if (msgEl) msgEl.style.display = visible === 0 ? 'block' : 'none';
    });
  });
})();
</script>
{% endraw %}
