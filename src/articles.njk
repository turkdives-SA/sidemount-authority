---
layout: base.njk
title: Articles
description: Field notes, industry opinion, safety standards, and training insights from a RAID Tech Trimix Sidemount Instructor.
permalink: /articles/
---
<section class="page-hero">
  <p class="page-label">From the field</p>
  <h1>Articles</h1>
  <p class="page-intro">Gear. Safety. Standards. Training. No filler — just what matters underwater and in the industry.</p>
</section>

<section class="articles-filters" aria-label="Filter articles by category">
  <button class="filter-btn active" data-filter="all">All</button>
  <button class="filter-btn" data-filter="gear">Gear</button>
  <button class="filter-btn" data-filter="safety">Safety & Standards</button>
  <button class="filter-btn" data-filter="industry">Industry</button>
  <button class="filter-btn" data-filter="training">Training</button>
</section>

<section class="posts-grid">
  <p class="posts-count"><span id="visible-count">{{ collections.posts | length }}</span> articles</p>
  {% for post in collections.posts | reverse %}
  <article class="post-card" data-category="{{ post.data.category or 'gear' }}">
    {% if post.data.hero_image %}
    <a href="{{ post.url }}">
      <img src="{{ post.data.hero_image }}" alt="{{ post.data.hero_image_alt }}" loading="lazy">
    </a>
    {% endif %}
    <div class="post-card__body">
      <div class="post-card__meta">
        <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
        {% if post.data.readTime %}<span>{{ post.data.readTime }} min read</span>{% endif %}
        {% if post.data.category %}<span class="post-tag post-tag--{{ post.data.category }}">{{ post.data.category }}</span>{% endif %}
