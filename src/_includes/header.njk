<header class="site-header" id="site-header">

  <div class="hud-corner hud-top-left">
    <span class="hud-corner-sep">—</span>
    <span class="hud-corner-label">LAT</span>
    <span class="hud-corner-value">24.5551° N</span>
  </div>

  <div class="hud-corner hud-top-right">
    <span class="hud-corner-label">DEPTH</span>
    <span class="hud-corner-value">55.4 M</span>
    <span class="hud-corner-sep">—</span>
  </div>

  <div class="header-inner">
    <a href="/" class="header-logo" aria-label="{{ site.name }} — Home">
      <img src="/images/logo-wordmark.webp" alt="{{ site.name }}" width="160" height="36" />
    </a>
    <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="primary-nav" aria-label="Toggle navigation">
      <span class="hamburger"></span>
    </button>
    <nav class="primary-nav" id="primary-nav" aria-label="Primary navigation">
      <ul class="nav-list">
        <li><a href="/" class="nav-link{% if page.url == '/' %} active{% endif %}">Home</a></li>
        <li><a href="/training/" class="nav-link{% if '/training' in page.url %} active{% endif %}">Training</a></li>
        <li><a href="/gear-tips/" class="nav-link{% if '/gear-tips' in page.url %} active{% endif %}">Gear Tips</a></li>
        <li><a href="/instructors/" class="nav-link{% if '/instructors' in page.url %} active{% endif %}">Instructors</a></li>
        <li><a href="/about/" class="nav-link{% if '/about' in page.url %} active{% endif %}">About</a></li>
        <li><a href="/contact/" class="nav-link nav-link-cta">Contact</a></li>
      </ul>
    </nav>
  </div>

  <div class="hud-corner hud-bottom-left">
    <span class="hud-corner-sep">—</span>
    <span class="hud-corner-label">SAC</span>
    <span class="hud-corner-value">16 L/MIN</span>
  </div>

  <div class="hud-corner hud-bottom-right">
    <span class="hud-corner-label">TRIM</span>
    <span class="hud-corner-value">LOCKED</span>
    <span class="hud-corner-sep">—</span>
  </div>

</header>
